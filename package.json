{
  "name": "salesnav-url-generator",
  "version": "1.0.0",
  "description": "Generate Sales Navigator URLs from natural language queries",
  "type": "module",
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --test --loader ts-node/esm src/tests/*.spec.ts",
    "frontend": "vite",
    "frontend:build": "vite build",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run build\" \"npm run frontend\" \"npm run server\""
  },
  "keywords": [
    "linkedin",
    "sales-navigator",
    "url-generator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
