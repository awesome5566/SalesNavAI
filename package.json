{
  "name": "salesnav-url-generator",
  "version": "1.0.0",
  "description": "Generate Sales Navigator URLs from natural language queries",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:all": "pnpm run build && cd frontend && pnpm install && pnpm run build",
    "build:vercel": "pnpm run frontend:build",
    "frontend": "vite",
    "frontend:build": "vite build",
    "start": "node dist/cli.js",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "server": "node server.js",
    "test": "node --test --loader ts-node/esm src/tests/*.spec.ts",
    "dev:full": "concurrently \"pnpm run build\" \"pnpm run frontend\" \"pnpm run server\""
  },
  "keywords": [
    "linkedin",
    "sales-navigator",
    "url-generator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.76.1",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.546.0",
    "openai": "^4.77.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^20.19.22",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
