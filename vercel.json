{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/build-url.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    }
  },
  "includeFiles": [
    "facet-store.json",
    "geoId.csv",
    "Industry IDs.csv"
  ]
}




